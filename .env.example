# Root env consumed by docker-compose. Copy to `.env` and fill in.

# --- MongoDB (compose-managed instance) ---
MONGO_USERNAME=admin
MONGO_PASSWORD=change-me-strong-password

# Full connection string the API uses. Defaults to the compose mongo service.
# Point this at MongoDB Atlas instead if you prefer a managed DB.
MONGODB_URI=mongodb://admin:change-me-strong-password@mongo:27017/swifttalk?authSource=admin

# --- Server secrets ---
JWT_SECRET=replace-with-a-long-random-string
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Public origin(s) of the client, comma-separated. Used for CORS.
# e.g. https://chat.example.com
CLIENT_URL=https://chat.example.com

# --- Image registry / tag (used by CI and compose) ---
# e.g. ghcr.io/your-username
REGISTRY=swifttalk
TAG=latest
