# Server environment (local dev). In Docker these come from the root .env.
MONGODB_URI=mongodb://localhost:27017/swifttalk
JWT_SECRET=replace-with-a-long-random-string
PORT=5000

# Comma-separated public client origins allowed by CORS (in addition to localhost)
CLIENT_URL=http://localhost:5173

# Cloudinary (image uploads)
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Leave unset locally. Vercel sets VERCEL=1 automatically on its platform.
# VERCEL=
